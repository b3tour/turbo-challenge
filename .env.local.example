# Supabase Configuration
# Uzyskasz te dane po utworzeniu projektu na supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj-anon-key

# Supabase Service Role (server-side only — NIE DODAWAJ NEXT_PUBLIC_!)
# Wymagany do: webhook PayU (notify route)
SUPABASE_SERVICE_ROLE_KEY=twoj-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Turbo Challenge

# PayU (produkcja)
PAYU_POS_ID=
PAYU_MD5_KEY=
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
PAYU_BASE_URL=https://secure.payu.com
NEXT_PUBLIC_PAYU_ENABLED=true
